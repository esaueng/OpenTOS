{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opentos.dev/schema/study-create.schema.json",
  "title": "StudyCreateRequest",
  "type": "object",
  "required": [
    "model",
    "units",
    "designRegion",
    "preservedRegions",
    "obstacleRegions",
    "loadCases",
    "material",
    "targets"
  ],
  "properties": {
    "model": {
      "type": "object",
      "required": ["format", "dataBase64"],
      "properties": {
        "format": {
          "type": "string",
          "enum": ["stl", "obj", "glb"]
        },
        "dataBase64": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "units": {
      "type": "string",
      "enum": ["mm", "in", "m"]
    },
    "designRegion": {
      "type": "object",
      "required": ["faceIndices"],
      "properties": {
        "faceIndices": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          },
          "minItems": 1
        }
      },
      "additionalProperties": false
    },
    "preservedRegions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "faceIndices"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "faceIndices": {
            "type": "array",
            "items": {
              "type": "integer",
              "minimum": 0
            },
            "minItems": 1
          }
        },
        "additionalProperties": false
      }
    },
    "obstacleRegions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "faceIndices"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "faceIndices": {
            "type": "array",
            "items": {
              "type": "integer",
              "minimum": 0
            },
            "minItems": 1
          }
        },
        "additionalProperties": false
      }
    },
    "loadCases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "fixedRegions", "forces"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "fixedRegions": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1
          },
          "forces": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["point", "direction", "magnitude", "unit"],
              "properties": {
                "point": {
                  "type": "array",
                  "items": {
                    "type": "number"
                  },
                  "minItems": 3,
                  "maxItems": 3
                },
                "direction": {
                  "type": "array",
                  "items": {
                    "type": "number"
                  },
                  "minItems": 3,
                  "maxItems": 3
                },
                "magnitude": {
                  "type": "number",
                  "exclusiveMinimum": 0
                },
                "unit": {
                  "type": "string",
                  "enum": ["N", "lb"]
                },
                "label": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "material": {
      "type": "string",
      "enum": ["Aluminum 6061"]
    },
    "targets": {
      "type": "object",
      "required": ["safetyFactor", "outcomeCount", "massReductionGoalPct"],
      "properties": {
        "safetyFactor": {
          "type": "number",
          "minimum": 1
        },
        "outcomeCount": {
          "type": "integer",
          "minimum": 2,
          "maximum": 12
        },
        "massReductionGoalPct": {
          "type": "number",
          "minimum": 1,
          "maximum": 90
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
